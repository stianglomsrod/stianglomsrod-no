---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---

<Base
  title="Stian Glomsrød — utvikler og UX"
  description="Personlig utviklerportefølje og sandbox. Et kjørende program, ikke en brosjyre."
>
  <main class="ramme">
    <Hero />
  </main>
</Base>

<style>
  .ramme {
    max-width: 1060px;
    margin: 0 auto;
    padding: 0 var(--s-6) var(--s-8);
  }

  @media (max-width: 680px) {
    .ramme {
      padding: 0 var(--s-4) var(--s-7);
    }
  }
</style>
