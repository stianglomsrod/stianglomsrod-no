---
import Side from '../layouts/Side.astro';

/* Skjelett: CHANGELOG-format — kuraterte milepæler + levende commit-feed
   + contribution-heatmap (Done 7). Korrektur-dialekten (modul B) er lov
   KUN her og i kolofonen. */
---

<Side
  title="Læringsreisen — Stian Glomsrød"
  description="CHANGELOG for et menneske: kuraterte milepæler og levende commits."
>
  <p class="kicker">CHANGELOG</p>
  <h1>Læringsreisen</h1>
  <p class="dempet">
    Kuraterte milepæler + levende commit-feed fra GitHub bygges her, i
    CHANGELOG-format.
  </p>
</Side>

<style>
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
  }
</style>
