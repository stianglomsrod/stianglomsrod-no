---
import Side from '../layouts/Side.astro';
import Changelog from '../components/Changelog.astro';
import Heatmap from '../components/Heatmap.astro';
---

<Side
  title="Læringsreisen — Stian Glomsrød"
  description="CHANGELOG for et menneske: kuraterte milepæler, levende commits og aktivitet."
>
  <p class="kicker">CHANGELOG</p>
  <h1>Læringsreisen</h1>
  <p class="dempet">
    Versjonsloggen for et menneske under utvikling: kuraterte milepæler øverst,
    levende commits fra GitHub under. Reisen er ikke ferdig — det er poenget.
  </p>
  <div class="stabel">
    <Changelog />
    <Heatmap />
  </div>
</Side>

<style>
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--tekst-label);
    letter-spacing: 0.12em;
    color: var(--dempet);
    margin: var(--s-7) 0 var(--s-2);
  }

  h1 {
    font-size: var(--tekst-tittel);
    margin: 0 0 var(--s-3);
  }

  .dempet {
    color: var(--dempet);
    max-width: 68ch;
  }

  .stabel {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
    margin-top: var(--s-5);
  }
</style>
