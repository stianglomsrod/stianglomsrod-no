---
import now from '../../now.json';
import { hentSisteCommits } from '../lib/github';

/* Ticker (Done 6): now.json + siste commit i 30s lineær loop. Pauser ved
   hover/fokus + eksplisitt pausekontroll ≥ 44×44 px med aria-pressed.
   Båndet er dekorativt (aria-hidden); skjermlesere får innholdet som
   statisk tekst. Reduced motion → statisk. */

const [commit] = await hentSisteCommits(1);
const commitDato = new Date(commit.tidspunkt).toLocaleDateString('nb-NO', {
  day: 'numeric',
  month: 'long',
});

const elementer = [
  { label: 'now.json → fullstack:', verdi: now.fullstack, farge: 'konst' },
  { label: 'ki:', verdi: now.ki, farge: 'tekst' },
  { label: 'status:', verdi: `søker ${now.soker}`, farge: 'signal' },
  {
    label: 'siste commit:',
    verdi: `${commit.sha} ${commit.melding}`,
    farge: 'tekst',
    tidspunkt: commit.tidspunkt,
  },
  { label: 'cookies servert:', verdi: '0', farge: 'tekst' },
];
---

<div class="ticker" data-paused="false">
  <p class="sr-only">
    Status: søker {now.soker}. Fullstack: {now.fullstack}. KI: {now.ki}.
    Siste commit {commitDato}: {commit.melding}.
  </p>
  <button
    type="button"
    id="ticker-pause"
    class="pauseknapp"
    aria-pressed="false"
    aria-label="Pause tickeren"
  >⏸</button>
  <div class="baand" aria-hidden="true">
    <div class="spor">
      {[0, 1].map(() => (
        <span class="halvdel">
          {elementer.map((e) => (
            <span class="element">
              <span class="e-label">{e.label}</span>
              <span class:list={['e-verdi', e.farge]}>
                {e.verdi}
                {e.tidspunkt && <span data-tidspunkt={e.tidspunkt}>({commitDato})</span>}
              </span>
              <span class="skille">▪</span>
            </span>
          ))}
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .ticker {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--linje);
    background: var(--terminal);
    overflow: hidden;
  }

  .pauseknapp {
    all: unset;
    box-sizing: border-box;
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--dempet);
    border-right: 1px solid var(--linje);
    cursor: pointer;
    flex-shrink: 0;
  }

  .pauseknapp:hover {
    color: var(--kode-tekst);
  }

  .pauseknapp:focus-visible {
    outline: 2px solid var(--term-groenn);
    outline-offset: -3px;
  }

  .baand {
    overflow: hidden;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .spor {
    display: flex;
    width: max-content;
    animation: ticker-loop 30s linear infinite;
    padding: 9px 0;
    white-space: nowrap;
  }

  .ticker[data-paused='true'] .spor,
  .baand:hover .spor {
    animation-play-state: paused;
  }

  @keyframes ticker-loop {
    to {
      transform: translateX(-50%);
    }
  }

  .halvdel {
    display: inline-flex;
  }

  .element {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
  }

  .e-label {
    color: var(--dempet);
    padding-left: 18px;
  }

  .e-verdi.tekst {
    color: var(--kode-tekst);
  }

  .e-verdi.signal {
    color: var(--term-groenn);
  }

  .e-verdi.konst {
    color: var(--syn-konst);
  }

  .skille {
    color: var(--term-groenn);
    padding-left: 18px;
  }

  /* Reduced motion: statisk bånd — første elementer synlige, ingen loop */
  @media (prefers-reduced-motion: reduce) {
    .spor {
      animation: none;
    }
  }
</style>

<script>
  import { settRelativeTider } from '../lib/relativ-tid';

  // Pausekontroll (aria-pressed) + relativ tid for siste commit.
  const ticker = document.querySelector<HTMLElement>('.ticker');
  const knapp = document.getElementById('ticker-pause');

  knapp?.addEventListener('click', () => {
    if (!ticker) return;
    const pauset = ticker.dataset.paused === 'true';
    ticker.dataset.paused = String(!pauset);
    knapp.setAttribute('aria-pressed', String(!pauset));
    knapp.setAttribute('aria-label', pauset ? 'Pause tickeren' : 'Start tickeren');
    knapp.textContent = pauset ? '⏸' : '▶';
  });

  settRelativeTider();
</script>
