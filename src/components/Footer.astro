  <div class="indre">
    <p class="kolofonlinje">
      © {aar} Stian Glomsrød · bygget i åpen dialog med Claude Code · ingen
      cookies, ingen sporing
    </p>
    <p class="lenker">
      <a href="/kolofon">kolofon</a>
      <span aria-hidden="true">·</span>
      <a href="/kolofon#tilgjengelighet">tilgjengelighet</a>
      <span aria-hidden="true">·</span>
      <a href="/kolofon#personvern">personvern</a>
      <span aria-hidden="true">·</span>
      <a href="mailto:stianglomsrod@gmail.com">e-post</a>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/stianglomsrod" rel="me">GitHub</a>
