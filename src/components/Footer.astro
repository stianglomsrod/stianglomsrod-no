<style>
  .bunn {
    border-top: 1px dashed var(--linje);
    margin-top: var(--s-8);
  }

  .indre {
    max-width: 1060px;
    margin: 0 auto;
    padding: var(--s-4) var(--s-6) var(--s-5);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .kolofonlinje {
    margin: 0;
    color: var(--dempet);
  }

  .lenker {
    margin: 0;
    color: var(--dempet);
    display: flex;
    gap: var(--s-2);
    flex-wrap: wrap;
  }
</style>
